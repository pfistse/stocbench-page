---
type Props = {
  title: string;
  installCommand: string;
};

const { title, installCommand } = Astro.props;
---

<section id="package-section" class="package-section" aria-labelledby="package-title">
  <div class="package-grid">
    <aside class="package-sidebar">
      <h2 id="package-title">{title}</h2>
      <div class="package-intro">
        <slot name="intro" />
      </div>

      <div class="install-card">
        <h3>Installation</h3>
        <code><span aria-hidden="true">$</span> {installCommand}</code>
      </div>
    </aside>

    <div class="demo-column" data-package-demo>
      <div class="demo-toolbar" role="tablist" aria-label="Package demos">
        <button
          id="code-demo-tab"
          class="demo-toggle is-active"
          type="button"
          role="tab"
          aria-selected="true"
          aria-controls="code-demo"
          data-demo-target="code"
        >
          Code
        </button>
        <button
          id="cli-demo-tab"
          class="demo-toggle"
          type="button"
          role="tab"
          aria-selected="false"
          aria-controls="cli-demo"
          data-demo-target="cli"
        >
          CLI
        </button>
      </div>

      <section id="code-demo" class="code-window demo-panel is-active" role="tabpanel" aria-labelledby="code-demo-tab" data-demo-panel="code">
        <button class="copy-button demo-copy" type="button" aria-label="Copy code demo" data-copy-code="code">
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M8 7a3 3 0 0 1 3-3h6a3 3 0 0 1 3 3v8a3 3 0 0 1-3 3h-1v-2h1a1 1 0 0 0 1-1V7a1 1 0 0 0-1-1h-6a1 1 0 0 0-1 1v1H8V7Z" />
            <path d="M4 11a3 3 0 0 1 3-3h6a3 3 0 0 1 3 3v6a3 3 0 0 1-3 3H7a3 3 0 0 1-3-3v-6Zm3-1a1 1 0 0 0-1 1v6a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1v-6a1 1 0 0 0-1-1H7Z" />
          </svg>
        </button>
        <div class="demo-window-body" data-copy-source="code">
          <slot name="code" />
        </div>
      </section>

      <section id="cli-demo" class="console-window demo-panel" role="tabpanel" aria-labelledby="cli-demo-tab" data-demo-panel="cli" hidden>
        <button class="copy-button demo-copy" type="button" aria-label="Copy CLI demo commands" data-copy-code="cli">
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M8 7a3 3 0 0 1 3-3h6a3 3 0 0 1 3 3v8a3 3 0 0 1-3 3h-1v-2h1a1 1 0 0 0 1-1V7a1 1 0 0 0-1-1h-6a1 1 0 0 0-1 1v1H8V7Z" />
            <path d="M4 11a3 3 0 0 1 3-3h6a3 3 0 0 1 3 3v6a3 3 0 0 1-3 3H7a3 3 0 0 1-3-3v-6Zm3-1a1 1 0 0 0-1 1v6a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1v-6a1 1 0 0 0-1-1H7Z" />
          </svg>
        </button>
        <div class="demo-window-body">
          <div class="cli-copy-source sr-only" data-copy-source="cli">
            <slot name="cli" />
          </div>

          <pre class="cli-commands" aria-label="CLI commands"><code><span class="cli-comment"># evaluate a model — checkpoint is pulled from Hugging Face by default</span>
<span class="cli-prompt">$</span> stocbench eval fm

<span class="cli-comment"># fully specified example with all benchmark options</span>
<span class="cli-prompt">$</span> stocbench eval dm --dataset incns_stoc \
    --sampling-schedules "uniform:10,uniform:20,uniform:30" \
    --ensemble-size 1000 --n-inits 48 --rollout-steps 10 \
    --output-dir runs/my_dm_eval

<span class="cli-comment"># evaluate your own model class</span>
<span class="cli-prompt">$</span> stocbench eval-custom \
    --model-class my_pkg.models:MyModel \
    --checkpoint path/to/ckpt.ckpt --dataset incns_stoc

<span class="cli-comment"># render plots for completed runs</span>
<span class="cli-prompt">$</span> stocbench plot runs/my_dm_eval --output-dir plots/</code></pre>

          <div class="cli-divider" aria-hidden="true">
            <span>example output — stocbench eval dm</span>
          </div>

          <div class="cli-output">
            <fieldset class="cli-panel cli-config">
              <legend>run configuration</legend>
              <dl>
                <div><dt>model</dt><dd>dm</dd></div>
                <div><dt>dataset</dt><dd>hf:64</dd></div>
                <div><dt>checkpoint</dt><dd>hf:dm/@max/last-ema.ckpt</dd></div>
                <div><dt>device</dt><dd>cuda:0</dd></div>
                <div><dt>seed</dt><dd>42</dd></div>
                <div><dt>sampling schedule</dt><dd>uniform:10, uniform:20, uniform:30</dd></div>
                <div><dt>ensemble size</dt><dd>1000</dd></div>
                <div><dt>rollout steps</dt><dd>10</dd></div>
                <div><dt>batch size</dt><dd>400</dd></div>
                <div><dt>n-inits</dt><dd>48</dd></div>
              </dl>
            </fieldset>

            <div class="cli-panel cli-results">
              <div class="cli-results-title" aria-hidden="true">
                <span>elapsed: 0:02:20</span>
                <span>results</span>
                <span>eta: 4:28:32</span>
              </div>
              <table>
                <thead>
                  <tr>
                    <th>schedule</th>
                    <th>mean err</th>
                    <th>std err</th>
                    <th>energy dist</th>
                    <th>enstrophy err</th>
                    <th>progress</th>
                  </tr>
                </thead>
                <tbody>
                  <tr>
                    <td>uniform:10</td>
                    <td>0.04859</td>
                    <td>0.07294</td>
                    <td>0.04478</td>
                    <td>.</td>
                    <td>5%</td>
                  </tr>
                  <tr>
                    <td>uniform:20</td>
                    <td>.</td>
                    <td>.</td>
                    <td>.</td>
                    <td>.</td>
                    <td>0%</td>
                  </tr>
                  <tr>
                    <td>uniform:30</td>
                    <td>.</td>
                    <td>.</td>
                    <td>.</td>
                    <td>.</td>
                    <td>0%</td>
                  </tr>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </section>
    </div>
  </div>
</section>

<script>
  const demoRoot = document.querySelector("[data-package-demo]");
  const demoToggles = demoRoot?.querySelectorAll("[data-demo-target]");
  const demoPanels = demoRoot?.querySelectorAll("[data-demo-panel]");

  demoToggles?.forEach((toggle) => {
    toggle.addEventListener("click", () => {
      const target = toggle.getAttribute("data-demo-target");

      demoToggles.forEach((button) => {
        const isActive = button === toggle;
        button.classList.toggle("is-active", isActive);
        button.setAttribute("aria-selected", String(isActive));
      });

      demoPanels?.forEach((panel) => {
        const isActive = panel.getAttribute("data-demo-panel") === target;
        panel.classList.toggle("is-active", isActive);
        panel.toggleAttribute("hidden", !isActive);
      });
    });
  });

  document.querySelectorAll("[data-copy-code]").forEach((copyButton) => {
    copyButton.addEventListener("click", async () => {
      const target = copyButton.getAttribute("data-copy-code");
      const codeBlock = document.querySelector(`[data-copy-source="${target}"]`);
      const code = codeBlock?.textContent?.trim();
      if (!code) return;
      await navigator.clipboard.writeText(code);

      const originalLabel = copyButton.getAttribute("aria-label") ?? "Copy code";
      copyButton.setAttribute("aria-label", "Copied");
      setTimeout(() => copyButton.setAttribute("aria-label", originalLabel), 1200);
    });
  });
</script>
