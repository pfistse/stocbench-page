---
export type ProjectLink = {
  label: string;
  href: string;
  kind: "arxiv" | "github" | "huggingface" | "package";
};

type Props = {
  links?: ProjectLink[];
};

const links = Astro.props.links ?? [
  { label: "arXiv", href: "https://arxiv.org", kind: "arxiv" },
  { label: "GitHub", href: "https://github.com", kind: "github" },
  { label: "Hugging Face", href: "https://huggingface.co", kind: "huggingface" },
  { label: "pip Package", href: "#package-section", kind: "package" },
];
---

<nav class="link-buttons" aria-label="Project links">
  {links.map((link) => (
    <a class:list={[link.kind === "package" && "package-jump"]} href={link.href} target={link.href.startsWith("http") ? "_blank" : undefined} rel={link.href.startsWith("http") ? "noreferrer" : undefined}>
      {link.kind === "arxiv" && (
        <span class="brand-badge arxiv-badge" aria-hidden="true">
          <img class="brand-image brand-image-arxiv" src="https://arxiv.org/static/browse/0.3.4/images/arxiv-logomark-small-white.svg" alt="" />
        </span>
      )}
      {link.kind === "github" && (
        <svg class="brand-icon" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M12 .7a11.3 11.3 0 0 0-3.58 22.03c.57.1.78-.25.78-.55v-2.15c-3.18.7-3.85-1.36-3.85-1.36-.52-1.32-1.27-1.67-1.27-1.67-1.04-.71.08-.7.08-.7 1.15.08 1.75 1.18 1.75 1.18 1.02 1.75 2.68 1.25 3.34.95.1-.74.4-1.25.72-1.54-2.54-.29-5.21-1.27-5.21-5.65 0-1.25.45-2.27 1.18-3.07-.12-.29-.51-1.45.11-3.03 0 0 .96-.31 3.14 1.17a10.9 10.9 0 0 1 5.72 0c2.18-1.48 3.14-1.17 3.14-1.17.62 1.58.23 2.74.11 3.03.73.8 1.17 1.82 1.17 3.07 0 4.39-2.68 5.36-5.23 5.64.41.36.77 1.06.77 2.14v3.18c0 .31.21.66.79.55A11.3 11.3 0 0 0 12 .7Z" />
        </svg>
      )}
      {link.kind === "huggingface" && <img class="brand-image brand-image-hf" src="https://huggingface.co/front/assets/huggingface_logo-noborder.svg" alt="" aria-hidden="true" />}
      {link.kind === "package" && (
        <svg class="brand-icon" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M12 2.8 4 6.8v10.4l8 4 8-4V6.8l-8-4Zm0 2.2 5.55 2.78L12 10.56 6.45 7.78 12 5Zm-6 4.36 5 2.5v6.25l-5-2.5V9.36Zm7 8.75v-6.25l5-2.5v6.25l-5 2.5Z" />
        </svg>
      )}
      <span>{link.label}</span>
    </a>
  ))}
</nav>
